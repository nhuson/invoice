# Root environment used by docker-compose.
# Copy to .env and adjust as needed before running `docker compose up`.

# Database
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=simple_invoice
DB_PORT=5432

# Backend
BACKEND_PORT=3000
JWT_SECRET=please-change-this-secret
JWT_EXPIRES_IN=3600
CORS_ORIGIN=http://localhost:8080

# Seed account
SEED_USER_EMAIL=admin@gmail.com
SEED_USER_PASSWORD=Password123
SEED_USER_FULLNAME=Admin

# Frontend
FRONTEND_PORT=8080
VITE_API_BASE_URL=http://localhost:3000/v1
