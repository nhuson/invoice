# Application
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Database (use DATABASE_URL or the discrete DB_* values)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/simple_invoice
DB_HOST=localhost
